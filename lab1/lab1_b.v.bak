module lab1_b(
input [17:15] SW,
output [6:0] HEX7,HEX6,HEX5,HEX4,HEX3,HEX2,HEX1,HEX0
);

wire [2:0] H7,H6,H5,H4,H3,H2,H1,H0;

assign H7 = (SW==3'b000)?3'b111:
            (SW==3'b001)?3'b111:
            (SW==3'b010)?3'b000:
            (SW==3'b011)?3'b001:
            (SW==3'b100)?3'b010:
            (SW==3'b101)?3'b010:
            (SW==3'b110)?3'b011:
                         3'b111;

assign H6 = (SW==3'b000)?3'b111:
            (SW==3'b001)?3'b000:
            (SW==3'b010)?3'b001:
            (SW==3'b011)?3'b010:
            (SW==3'b100)?3'b010:
            (SW==3'b101)?3'b011:
            (SW==3'b110)?3'b111:
                         3'b111;

assign H5 = (SW==3'b000)?3'b000:
            (SW==3'b001)?3'b001:
            (SW==3'b010)?3'b010:
            (SW==3'b011)?3'b010:
            (SW==3'b100)?3'b011:
            (SW==3'b101)?3'b111:
            (SW==3'b110)?3'b111:
                         3'b111;

assign H4 = (SW==3'b000)?3'b001:
            (SW==3'b001)?3'b010:
            (SW==3'b010)?3'b010:
            (SW==3'b011)?3'b011:
            (SW==3'b100)?3'b111:
            (SW==3'b101)?3'b111:
            (SW==3'b110)?3'b111:
                         3'b000;

assign H3 = (SW==3'b000)?3'b010:
            (SW==3'b001)?3'b010:
            (SW==3'b010)?3'b011:
            (SW==3'b011)?3'b111:
            (SW==3'b100)?3'b111:
            (SW==3'b101)?3'b111:
            (SW==3'b110)?3'b000:
                         3'b001;

assign H2 = (SW==3'b000)?3'b010:
            (SW==3'b001)?3'b011:
            (SW==3'b010)?3'b111:
            (SW==3'b011)?3'b111:
            (SW==3'b100)?3'b111:
            (SW==3'b101)?3'b000:
            (SW==3'b110)?3'b001:
                         3'b010;

assign H1 = (SW==3'b000)?3'b011:
            (SW==3'b001)?3'b111:
            (SW==3'b010)?3'b111:
            (SW==3'b011)?3'b111:
            (SW==3'b100)?3'b000:
            (SW==3'b101)?3'b001:
            (SW==3'b110)?3'b010:
                         3'b010;

assign H0 = (SW==3'b000)?3'b111:
            (SW==3'b001)?3'b111:
            (SW==3'b010)?3'b111:
            (SW==3'b011)?3'b000:
            (SW==3'b100)?3'b001:
            (SW==3'b101)?3'b010:
            (SW==3'b110)?3'b010:
                         3'b011;
segment_7 s0(H0,HEX0);
segment_7 s1(H1,HEX1);
segment_7 s2(H2,HEX2);
segment_7 s3(H3,HEX3);
segment_7 s4(H4,HEX4);
segment_7 s5(H5,HEX5);
segment_7 s6(H6,HEX6);
segment_7 s7(H7,HEX7);
endmodule
