module clock(
	input CLK,reset,
	input [2:0] H0,H1,M0,M1,S0,S1,
	output [7:0] led0,led1,led2,led3,led4,led5,led6,led7
);
	wire a;
	reg s0,s1,s2,s3,s4,s5;
	assign a = 1;
	delay_1s (CLK,s5)
	reg [3:0] Q0,Q1,Q2,Q3,Q4,Q5; //H,H:M,M:S,S
	count_load h0(a,s0,Reset,load,H0,Q0);
	count_load h1(a,s1,Reset,load,H1,Q1);
	count_load m0(a,s2,Reset,load,M0,Q2);
	count_load m1(a,s3,Reset,load,M1,Q3);
	count_load m0(a,s4,Reset,load,S0,Q4);
	count_load m1(a,s5,Reset,load,S1,Q5);
	bcd_to_led hex7(Q0,led0);
	bcd_to_led hex6(Q1,led1);
	bcd_to_led hex5(Q2,led2);
	bcd_to_led hex4(Q3,led3);
	bcd_to_led hex3(Q4,led4);
	bcd_to_led hex2(Q5,led5);
	
	always @ (posedge s) begin
		if(Q5 == 4'b0111) begin
			s4 <= 1'b1;
			if(Q4 == 4'b0111) begin
				s3 <= 1'b1;
				if(Q3 == 4'b0111) begin
					s2 <= 1'b1;
					if(Q2 == 4'b0111) begin
						s1 <= 1'b1;
						if(Q1 == 4'b0111) begin
							s0 <= 1'b1;
						end else if( Q0 == 4'd2 and Q1 == 4'd4) begin
								 Q0 <= 4'd0;
								 Q1 <= 4'd0;
							 end
					end
				end
			end
		end else begin
				 s4 <= 1'b0;
				 s3 <= 1'b0;
				 s2 <= 1'b0;
				 s1 <= 1'b0;
				 s0 <= 1'b0;
			 end
	end
endmodule