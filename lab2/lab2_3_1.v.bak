module lab2_3_1(
	input CLK,reset,ena,
	output [6:0]H0,H1,H2,H3,H4,H5,H6,H7
);
	reg [3:0]Q;
	always @(posedge CLK or negedge reset) begin
		if(!reset) begin
			if(Q == 4'b0111) begin
				Q <= 4'b0000;
			end 
		end
	end
	count_4bit_2(ena,CLK,reset,Q);
	lab1_b([2:0]Q,H0,H1,H2,H3,H4,H5,H6,H7);
endmodule
	